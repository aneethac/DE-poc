    "# ============================================================\n",
    "# CELL 11 — DUPLICATE, RI, AND CUSTOM SQL CHECKS\n",
    "# ============================================================\n",
    "\n",
    "def check_duplicates(spark: SparkSession, cfg: dict, tc: dict,\n",
    "                     src_df: DataFrame, tgt_df: DataFrame,\n",
    "                     runtime_cfg: dict) -> list:\n",
    "    \"\"\"\n",
    "    Check for duplicate rows in source and target.\n",
    "\n",
    "    Guard: warn + skip if no partition filter and not force_duplicate_scan.\n",
    "    \"\"\"\n",
    "    results = []\n",
    "    t_start = time.time()\n",
    "\n",
    "    try:\n",
    "        where_clause = build_partition_filter(tc)\n",
    "        force        = tc.get('force_duplicate_scan', False)\n",
    "\n",
    "        if not where_clause and not force:\n",
    "            msg = ('Duplicate check skipped — no partition filter provided. '\n",
    "                   'Set force_duplicate_scan=true in CSV to override.')\n",
    "            logger.warning(msg)\n",
    "            return [make_result_row(cfg, tc, 'DETAIL', 'duplicate',\n",
    "                'WARNED', msg, duration_seconds=round(time.time() - t_start, 2))]\n",
    "\n",
    "        for label, df in [('source', src_df), ('target', tgt_df)]:\n",
    "            total     = df.count()\n",
    "            distinct  = df.distinct().count()\n",
    "            dup_count = total - distinct\n",
    "            status    = 'PASSED' if dup_count == 0 else 'FAILED'\n",
    "            reason    = f'{label}: {total:,} rows, {distinct:,} distinct, {dup_count:,} duplicates'\n",
    "            results.append(make_result_row(cfg, tc, 'DETAIL', 'duplicate',\n",
    "                status, reason,\n",
    "                expected_value=0, actual_value=dup_count,\n",
    "                duration_seconds=round(time.time() - t_start, 2)))\n",
    "\n",
    "    except Exception as e:\n",
    "        results.append(make_result_row(cfg, tc, 'DETAIL', 'duplicate',\n",
    "            'FAILED', f'Duplicate check error: {str(e)}',\n",
    "            duration_seconds=round(time.time() - t_start, 2)))\n",
    "\n",
    "    return results\n",
    "\n",
    "\n",
    "def check_referential_integrity(spark: SparkSession, cfg: dict, tc: dict,\n",
    "                                 runtime_cfg: dict) -> list:\n",
    "    \"\"\"\n",
    "    Check referential integrity — source PKs exist in target.\n",
    "\n",
    "    Guard: warn + skip if no partition filter and not force_ri_scan.\n",
    "    Requires primary_keys to be set in CSV config.\n",
    "    \"\"\"\n",
    "    results = []\n",
    "    t_start = time.time()\n",
    "\n",
    "    try:\n",
    "        pks          = tc.get('primary_keys', [])\n",
    "        where_clause = build_partition_filter(tc)\n",
    "        force        = tc.get('force_ri_scan', False)\n",
    "\n",
    "        if not pks:\n",
    "            return [make_result_row(cfg, tc, 'DETAIL', 'ri',\n",
    "                'SKIPPED', 'RI check skipped — no primary_keys defined in CSV',\n",
    "                duration_seconds=round(time.time() - t_start, 2))]\n",
    "\n",
    "        if not where_clause and not force:\n",
    "            msg = ('RI check skipped — no partition filter provided. '\n",
    "                   'Set force_ri_scan=true in CSV to override.')\n",
    "            logger.warning(msg)\n",
    "            return [make_result_row(cfg, tc, 'DETAIL', 'ri',\n",
    "                'WARNED', msg, duration_seconds=round(time.time() - t_start, 2))]\n",
    "\n",
    "        src_df = spark.table(tc['source_full'])\n",
    "        tgt_df = spark.table(tc['target_full'])\n",
    "\n",
    "        if where_clause:\n",
    "            src_df = src_df.filter(where_clause)\n",
    "            tgt_df = tgt_df.filter(where_clause)\n",
    "\n",
    "        src_keys = src_df.select(pks).distinct()\n",
    "        tgt_keys = tgt_df.select(pks).distinct()\n",
    "\n",
    "        orphans = src_keys.subtract(tgt_keys).count()\n",
    "        duration = round(time.time() - t_start, 2)\n",
    "\n",
    "        results.append(make_result_row(cfg, tc, 'DETAIL', 'ri',\n",
    "            'PASSED' if orphans == 0 else 'FAILED',\n",
    "            f'{orphans:,} source keys missing from target' if orphans > 0 else 'All source keys found in target',\n",
    "            expected_value=0, actual_value=orphans,\n",
    "            duration_seconds=duration))\n",
    "\n",
    "    except Exception as e:\n",
    "        results.append(make_result_row(cfg, tc, 'DETAIL', 'ri',\n",
    "            'FAILED', f'RI check error: {str(e)}',\n",
    "            duration_seconds=round(time.time() - t_start, 2)))\n",
    "\n",
    "    return results\n",
    "\n",
    "\n",
    "def check_custom_sql(spark: SparkSession, cfg: dict, tc: dict) -> list:\n",
    "    \"\"\"\n",
    "    Run a custom SQL assertion.\n",
    "    SQL should return a single row with a single integer column.\n",
    "    Check PASSES if result == 0.\n",
    "\n",
    "    Placeholder {table} in SQL is replaced with source_full path.\n",
    "    \"\"\"\n",
    "    results = []\n",
    "    t_start = time.time()\n",
    "\n",
    "    try:\n",
    "        sql = tc.get('custom_sql')\n",
    "        if not sql:\n",
    "            return results\n",
    "\n",
    "        sql = sql.replace('{source_table}', tc['source_full'])\n",
    "        sql = sql.replace('{target_table}', tc['target_full'])\n",
    "        sql = sql.replace('{table}',        tc['source_full'])  # convenience alias\n",
    "\n",
    "        result_val = spark.sql(sql).collect()[0][0]\n",
    "        duration   = round(time.time() - t_start, 2)\n",
    "\n",
    "        results.append(make_result_row(cfg, tc, 'DETAIL', 'custom_sql',\n",
    "            'PASSED' if result_val == 0 else 'FAILED',\n",
    "            f'Custom SQL returned: {result_val} (expected 0 for PASS)',\n",
    "            expected_value=0, actual_value=result_val,\n",
    "            duration_seconds=duration))\n",
    "\n",
    "    except Exception as e:\n",
    "        results.append(make_result_row(cfg, tc, 'DETAIL', 'custom_sql',\n",
    "            'FAILED', f'Custom SQL error: {str(e)}',\n",
    "            duration_seconds=round(time.time() - t_start, 2)))\n",
    "\n",
    "    return results\n",
    "\n",
    "print('Duplicate / RI / Custom SQL checks ready.')"
   ]
  },
