    "# ============================================================\n",
    "# CELL 8 — AGGREGATE CHECKS\n",
    "# Single-pass: computes count, min, max, sum, mean, stddev\n",
    "# (and optionally mode) for all numerical columns in one Spark job.\n",
    "# ============================================================\n",
    "\n",
    "def check_aggregates(spark: SparkSession, cfg: dict, tc: dict,\n",
    "                     src_df: DataFrame, tgt_df: DataFrame,\n",
    "                     col_types: dict) -> list:\n",
    "    \"\"\"\n",
    "    Compare aggregate stats for all numerical columns.\n",
    "\n",
    "    Single-pass: all columns aggregated in one Spark action.\n",
    "    Tolerances: absolute (abs_tol) and relative (rel_tol) — fail if BOTH exceeded.\n",
    "\n",
    "    Returns: List of result row dicts\n",
    "    \"\"\"\n",
    "    results = []\n",
    "    t_start = time.time()\n",
    "\n",
    "    try:\n",
    "        num_cols = [c for c, t in col_types.items() if t == 'numerical' and c in src_df.columns and c in tgt_df.columns]\n",
    "\n",
    "        if not num_cols:\n",
    "            return results\n",
    "\n",
    "        abs_tol  = tc.get('aggregate_tolerance_abs', 0.0)\n",
    "        rel_tol  = tc.get('aggregate_tolerance_rel', 0.0)\n",
    "        enable_mode = tc.get('enable_mode', False)\n",
    "\n",
    "        def compute_aggs(df: DataFrame, cols: list, enable_mode: bool) -> dict:\n",
    "            \"\"\"Compute aggregates for all numerical columns in a single pass.\"\"\"\n",
    "            agg_exprs = []\n",
    "            for c in cols:\n",
    "                agg_exprs += [\n",
    "                    F.count(F.col(c)).alias(f'{c}__count'),\n",
    "                    F.min(F.col(c)).cast('double').alias(f'{c}__min'),\n",
    "                    F.max(F.col(c)).cast('double').alias(f'{c}__max'),\n",
    "                    F.sum(F.col(c)).cast('double').alias(f'{c}__sum'),\n",
    "                    F.mean(F.col(c)).alias(f'{c}__mean'),\n",
    "                    F.stddev(F.col(c)).alias(f'{c}__stddev'),\n",
    "                ]\n",
    "                if enable_mode:\n",
    "                    # Mode = top-1 from frequency — no extra shuffle needed if top_n already computed\n",
    "                    # Use a subquery approach per column (only when explicitly enabled)\n",
    "                    pass  # Mode computed separately below when enabled\n",
    "\n",
    "            row = df.agg(*agg_exprs).collect()[0].asDict()\n",
    "            return row\n",
    "\n",
    "        src_aggs = compute_aggs(src_df, num_cols, enable_mode)\n",
    "        tgt_aggs = compute_aggs(tgt_df, num_cols, enable_mode)\n",
    "        duration = round(time.time() - t_start, 2)\n",
    "\n",
    "        metrics = ['count', 'min', 'max', 'sum', 'mean', 'stddev']\n",
    "\n",
    "        for col in num_cols:\n",
    "            for metric in metrics:\n",
    "                src_val = src_aggs.get(f'{col}__{metric}')\n",
    "                tgt_val = tgt_aggs.get(f'{col}__{metric}')\n",
    "\n",
    "                if src_val is None and tgt_val is None:\n",
    "                    status = 'PASSED'\n",
    "                    reason = f'{metric} both null'\n",
    "                elif src_val is None or tgt_val is None:\n",
    "                    status = 'FAILED'\n",
    "                    reason = f'{metric} null mismatch: source={src_val}, target={tgt_val}'\n",
    "                else:\n",
    "                    try:\n",
    "                        diff = abs(float(src_val) - float(tgt_val))\n",
    "                        rel  = diff / max(abs(float(src_val)), 1e-10)\n",
    "                        # Pass if within absolute OR relative tolerance\n",
    "                        if diff <= abs_tol or rel <= rel_tol:\n",
    "                            status = 'PASSED'\n",
    "                            reason = f'{metric} within tolerance (diff={diff:.4f}, rel={rel:.4%})'\n",
    "                        else:\n",
    "                            status = 'FAILED'\n",
    "                            reason = f'{metric} exceeds tolerance (diff={diff:.4f} > abs_tol={abs_tol}, rel={rel:.4%} > rel_tol={rel_tol:.4%})'\n",
    "                    except Exception:\n",
    "                        # Non-numeric (e.g. count) — exact match\n",
    "                        status = 'PASSED' if src_val == tgt_val else 'FAILED'\n",
    "                        reason = f'{metric}: source={src_val}, target={tgt_val}'\n",
    "\n",
    "                results.append(make_result_row(cfg, tc, 'DETAIL', 'aggregates',\n",
    "                    status, reason,\n",
    "                    column_name=f'{col}.{metric}',\n",
    "                    expected_value=src_val, actual_value=tgt_val,\n",
    "                    duration_seconds=duration))\n",
    "\n",
    "    except Exception as e:\n",
    "        results.append(make_result_row(cfg, tc, 'DETAIL', 'aggregates',\n",
    "            'FAILED', f'Aggregate check error: {str(e)}',\n",
    "            duration_seconds=round(time.time() - t_start, 2)))\n",
    "\n",
    "    return results\n",
    "\n",
    "print('Aggregate check ready.')"
   ]
  },
