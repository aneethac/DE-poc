   "source": [
    "# ============================================================\n",
    "# CELL 12 — STATS COLLECTION & DRIFT DETECTION\n",
    "# ============================================================\n",
    "\n",
    "def collect_table_stats(spark: SparkSession, cfg: dict, tc: dict,\n",
    "                         df: DataFrame, side: str,\n",
    "                         full_table_path: str, col_types: dict) -> list:\n",
    "    \"\"\"\n",
    "    Collect detailed column stats for the regression_stats table.\n",
    "\n",
    "    Args:\n",
    "        side : 'SOURCE' or 'TARGET'\n",
    "\n",
    "    Returns: List of stat row dicts (one per column)\n",
    "    \"\"\"\n",
    "    rows      = []\n",
    "    top_n     = tc.get('top_n_frequent', 5)\n",
    "    exact     = tc.get('exact_distinct', False)\n",
    "    en_mode   = tc.get('enable_mode', False)\n",
    "\n",
    "    try:\n",
    "        total_rows    = df.count()\n",
    "        size_bytes    = get_table_size_bytes(spark, full_table_path)\n",
    "        col_count     = len(df.columns)\n",
    "\n",
    "        # Single-pass aggregation for all columns\n",
    "        agg_exprs = []\n",
    "        for c, ctype in col_types.items():\n",
    "            if c not in df.columns or ctype == 'complex':\n",
    "                continue\n",
    "            agg_exprs.append(F.count(F.when(F.col(c).isNull(), 1)).alias(f'{c}__nulls'))\n",
    "            if exact:\n",
    "                agg_exprs.append(F.countDistinct(c).alias(f'{c}__distinct'))\n",
    "            else:\n",
    "                agg_exprs.append(F.approx_count_distinct(c).alias(f'{c}__distinct'))\n",
    "\n",
    "            if ctype == 'numerical':\n",
    "                agg_exprs += [\n",
    "                    F.min(F.col(c)).cast('double').alias(f'{c}__min'),\n",
    "                    F.max(F.col(c)).cast('double').alias(f'{c}__max'),\n",
    "                    F.sum(F.col(c)).cast('double').alias(f'{c}__sum'),\n",
    "                    F.mean(F.col(c)).alias(f'{c}__mean'),\n",
    "                    F.stddev(F.col(c)).alias(f'{c}__stddev'),\n",
    "                    F.count(c).alias(f'{c}__count'),\n",
    "                ]\n",
    "            elif ctype == 'categorical':\n",
    "                agg_exprs += [\n",
    "                    F.count(F.when(F.col(c) == '', 1)).alias(f'{c}__empty'),\n",
    "                    F.min(F.length(F.col(c))).alias(f'{c}__min_len'),\n",
    "                    F.max(F.length(F.col(c))).alias(f'{c}__max_len'),\n",
    "                    F.avg(F.length(F.col(c))).alias(f'{c}__avg_len'),\n",
    "                ]\n",
    "            elif ctype == 'date':\n",
    "                agg_exprs += [\n",
    "                    F.min(c).cast('string').alias(f'{c}__min'),\n",
    "                    F.max(c).cast('string').alias(f'{c}__max'),\n",
    "                    F.datediff(F.max(c).cast('date'), F.min(c).cast('date')).alias(f'{c}__range'),\n",
    "                ]\n",
    "            elif ctype == 'boolean':\n",
    "                agg_exprs += [\n",
    "                    F.count(F.when(F.col(c) == True, 1)).alias(f'{c}__true'),\n",
    "                    F.count(F.when(F.col(c) == False, 1)).alias(f'{c}__false'),\n",
    "                ]\n",
    "\n",
    "        agg_row = df.agg(*agg_exprs).collect()[0].asDict() if agg_exprs else {}\n",
    "\n",
    "        # Top N per categorical column (separate action — can't do in single agg)\n",
    "        top_n_cache = {}\n",
    "        cat_cols = [c for c, t in col_types.items() if t == 'categorical' and c in df.columns]\n",
    "        for c in cat_cols:\n",
    "            top_vals = df.groupBy(c).count().orderBy(F.desc('count')).limit(top_n).collect()\n",
    "            top_n_cache[c] = json.dumps([{str(r[c]): r['count']} for r in top_vals])\n",
    "\n",
    "        # Mode per numerical column (optional)\n",
    "        mode_cache = {}\n",
    "        if en_mode:\n",
    "            num_cols = [c for c, t in col_types.items() if t == 'numerical' and c in df.columns]\n",
    "            for c in num_cols:\n",
    "                mode_row = df.groupBy(c).count().orderBy(F.desc('count')).limit(1).collect()\n",
    "                mode_cache[c] = float(mode_row[0][c]) if mode_row else None\n",
    "\n",
    "        # Build one row per column\n",
    "        for c, ctype in col_types.items():\n",
    "            if c not in df.columns:\n",
    "                continue\n",
    "\n",
    "            nulls    = agg_row.get(f'{c}__nulls', 0) or 0\n",
    "            distinct = agg_row.get(f'{c}__distinct', 0) or 0\n",
    "\n",
    "            row = {\n",
    "                'run_id'           : cfg['run_id'],\n",
    "                'run_timestamp'    : cfg['run_timestamp'],\n",
    "                'table_full_path'  : full_table_path,\n",
    "                'side'             : side,\n",
    "                'column_name'      : c,\n",
    "                'column_type'      : ctype,\n",
    "                'table_row_count'  : total_rows,\n",
    "                'table_size_bytes' : size_bytes,\n",
    "                'table_size_mb'    : round(size_bytes / 1_048_576, 2) if size_bytes else None,\n",
    "                'table_size_gb'    : round(size_bytes / 1_073_741_824, 4) if size_bytes else None,\n",
    "                'table_column_count': col_count,\n",
    "                'null_count'       : nulls,\n",
    "                'null_pct'         : round(nulls / max(total_rows, 1) * 100, 4),\n",
    "                'distinct_count'   : distinct,\n",
    "                'is_exact_distinct': exact,\n",
    "                # Numerical\n",
    "                'num_min'    : agg_row.get(f'{c}__min') if ctype == 'numerical' else None,\n",
    "                'num_max'    : agg_row.get(f'{c}__max') if ctype == 'numerical' else None,\n",
    "                'num_sum'    : agg_row.get(f'{c}__sum') if ctype == 'numerical' else None,\n",
    "                'num_mean'   : agg_row.get(f'{c}__mean') if ctype == 'numerical' else None,\n",
    "                'num_stddev' : agg_row.get(f'{c}__stddev') if ctype == 'numerical' else None,\n",
    "                'num_mode'   : mode_cache.get(c) if ctype == 'numerical' else None,\n",
    "                'num_count'  : agg_row.get(f'{c}__count') if ctype == 'numerical' else None,\n",
    "                # Categorical\n",
    "                'cat_min_length' : agg_row.get(f'{c}__min_len') if ctype == 'categorical' else None,\n",
    "                'cat_max_length' : agg_row.get(f'{c}__max_len') if ctype == 'categorical' else None,\n",
    "                'cat_avg_length' : round(float(agg_row.get(f'{c}__avg_len') or 0), 4) if ctype == 'categorical' else None,\n",
    "                'cat_empty_pct'  : round((agg_row.get(f'{c}__empty', 0) or 0) / max(total_rows, 1) * 100, 4) if ctype == 'categorical' else None,\n",
    "                'cat_top_n_values': top_n_cache.get(c) if ctype == 'categorical' else None,\n",
    "                # Date\n",
    "                'date_min'       : agg_row.get(f'{c}__min') if ctype == 'date' else None,\n",
    "                'date_max'       : agg_row.get(f'{c}__max') if ctype == 'date' else None,\n",
    "                'date_range_days': agg_row.get(f'{c}__range') if ctype == 'date' else None,\n",
    "                # Boolean\n",
    "                'bool_true_pct'  : round((agg_row.get(f'{c}__true', 0) or 0) / max(total_rows, 1) * 100, 4) if ctype == 'boolean' else None,\n",
    "                'bool_false_pct' : round((agg_row.get(f'{c}__false', 0) or 0) / max(total_rows, 1) * 100, 4) if ctype == 'boolean' else None,\n",
    "                # Drift flags (computed below)\n",
    "                'drift_null_pct_flag'     : False,\n",
    "                'drift_distinct_pct_flag' : False,\n",
    "                'drift_rowcount_flag'     : False,\n",
    "                'drift_mean_flag'         : False,\n",
    "                'drift_new_category_flag' : False,\n",
    "                'drift_top_value_changed' : False,\n",
    "                'drift_notes'             : None,\n",
    "            }\n",
    "            rows.append(row)\n",
    "\n",
    "    except Exception as e:\n",
    "        logger.error(f'Stats collection error for {full_table_path}: {e}')\n",
    "\n",
    "    return rows\n",
    "\n",
    "\n",
    "def compute_drift_flags(spark: SparkSession, cfg: dict, tc: dict,\n",
    "                         current_rows: list, output_table: str) -> list:\n",
    "    \"\"\"\n",
    "    Compare current stats against previous run stats and set drift flags.\n",
    "\n",
    "    Only runs if drift thresholds are set in CSV config.\n",
    "\n",
    "    Returns: Updated stat rows with drift flags populated.\n",
    "    \"\"\"\n",
    "    # Check if any drift thresholds are configured\n",
    "    has_thresholds = any([\n",
    "        tc.get('drift_null_pct_threshold'),\n",
    "        tc.get('drift_distinct_pct_threshold'),\n",
    "        tc.get('drift_rowcount_pct_threshold'),\n",
    "        tc.get('drift_numeric_mean_threshold'),\n",
    "    ])\n",
    "\n",
    "    if not has_thresholds:\n",
    "        return current_rows\n",
    "\n",
    "    try:\n",
    "        # Get most recent previous run stats for this table\n",
    "        prev_df = spark.sql(f\"\"\"\n",
    "            SELECT * FROM {output_table}\n",
    "            WHERE table_full_path = '{tc['source_full']}'\n",
    "            AND run_id != '{cfg['run_id']}'\n",
    "            AND side = 'SOURCE'\n",
    "            ORDER BY run_timestamp DESC\n",
    "            LIMIT 1000\n",
    "        \"\"\")\n",
    "\n",
    "        if prev_df.count() == 0:\n",
    "            return current_rows  # No previous run to compare against\n",
    "\n",
    "        prev_rows = {r['column_name']: r.asDict() for r in prev_df.collect()}\n",
    "\n",
    "        null_thr    = tc.get('drift_null_pct_threshold')\n",
    "        dist_thr    = tc.get('drift_distinct_pct_threshold')\n",
    "        row_thr     = tc.get('drift_rowcount_pct_threshold')\n",
    "        mean_thr    = tc.get('drift_numeric_mean_threshold')\n",
    "\n",
    "        for row in current_rows:\n",
    "            col  = row['column_name']\n",
    "            prev = prev_rows.get(col)\n",
    "            if not prev:\n",
    "                continue\n",
    "\n",
    "            notes = []\n",
    "\n",
    "            # Null % drift\n",
    "            if null_thr and row['null_pct'] is not None and prev.get('null_pct') is not None:\n",
    "                null_increase = row['null_pct'] - prev['null_pct']\n",
    "                if null_increase > null_thr:\n",
    "                    row['drift_null_pct_flag'] = True\n",
    "                    notes.append(f'null_pct increased by {null_increase:.2f}% (threshold={null_thr}%)')\n",
    "\n",
    "            # Distinct count drift\n",
    "            if dist_thr and row['distinct_count'] and prev.get('distinct_count'):\n",
    "                dist_change = abs(row['distinct_count'] - prev['distinct_count']) / max(prev['distinct_count'], 1) * 100\n",
    "                if dist_change > dist_thr:\n",
    "                    row['drift_distinct_pct_flag'] = True\n",
    "                    notes.append(f'distinct_count shifted by {dist_change:.2f}% (threshold={dist_thr}%)')\n",
    "\n",
    "            # Row count drift\n",
    "            if row_thr and row['table_row_count'] and prev.get('table_row_count'):\n",
    "                row_change = abs(row['table_row_count'] - prev['table_row_count']) / max(prev['table_row_count'], 1) * 100\n",
    "                if row_change > row_thr:\n",
    "                    row['drift_rowcount_flag'] = True\n",
    "                    notes.append(f'row_count changed by {row_change:.2f}% (threshold={row_thr}%)')\n",
    "\n",
    "            # Mean drift (numerical)\n",
    "            if mean_thr and row['num_mean'] is not None and prev.get('num_mean') is not None:\n",
    "                mean_change = abs(row['num_mean'] - prev['num_mean']) / max(abs(prev['num_mean']), 1e-10) * 100\n",
    "                if mean_change > mean_thr:\n",
    "                    row['drift_mean_flag'] = True\n",
    "                    notes.append(f'mean shifted by {mean_change:.2f}% (threshold={mean_thr}%)')\n",
    "\n",
    "            # New category detection\n",
    "            if row['cat_top_n_values'] and prev.get('cat_top_n_values'):\n",
    "                try:\n",
    "                    curr_cats = set(list(json.loads(row['cat_top_n_values'])[0].keys()) if json.loads(row['cat_top_n_values']) else [])\n",
    "                    prev_cats = set(list(json.loads(prev['cat_top_n_values'])[0].keys()) if json.loads(prev['cat_top_n_values']) else [])\n",
    "                    new_cats  = curr_cats - prev_cats\n",
    "                    if new_cats:\n",
    "                        row['drift_new_category_flag'] = True\n",
    "                        notes.append(f'New categories in top N: {new_cats}')\n",
    "                    # Top value change\n",
    "                    curr_top = list(curr_cats)[0] if curr_cats else None\n",
    "                    prev_top = list(prev_cats)[0] if prev_cats else None\n",
    "                    if curr_top != prev_top:\n",
    "                        row['drift_top_value_changed'] = True\n",
    "                        notes.append(f'Top frequent value changed: {prev_top} → {curr_top}')\n",
    "                except Exception:\n",
    "                    pass\n",
    "\n",
    "            row['drift_notes'] = '; '.join(notes) if notes else None\n",
    "\n",
    "    except Exception as e:\n",
    "        logger.warning(f'Drift computation error: {e}')\n",
    "\n",
    "    return current_rows\n",
    "\n",
    "print('Stats & drift functions ready.')"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": ["---\n## Section 5 — Logging (Delta Table Writers)\nWrites results and stats to `caife_utils` Delta tables."]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# ============================================================\n",
    "# CELL 13 — DELTA TABLE WRITERS\n",
    "# ============================================================\n",
    "\n",
    "def write_results(spark: SparkSession, rows: list, cfg: dict) -> None:\n",
    "    \"\"\"\n",
    "    Append result rows to regression_results Delta table.\n",
    "\n",
    "    Args:\n",
    "        rows : List of result row dicts from make_result_row()\n",
    "        cfg  : Runtime config dict\n",
    "    \"\"\"\n",
    "    if not rows:\n",
    "        return\n",
    "\n",
    "    output_table = f\"{cfg['default_catalog']}.{cfg['output_schema']}.regression_results\"\n",
    "\n",
    "    try:\n",
    "        df = spark.createDataFrame(pd.DataFrame(rows))\n",
    "        df.write.format('delta').mode('append').saveAsTable(output_table)\n",
    "        logger.info(f'Wrote {len(rows)} rows to {output_table}')\n",
    "    except Exception as e:\n",
    "        logger.error(f'Failed to write results: {e}')\n",
    "        raise\n",
    "\n",
    "\n",
    "def write_stats(spark: SparkSession, rows: list, cfg: dict) -> None:\n",
    "    \"\"\"\n",
    "    Append stat rows to regression_stats Delta table.\n",
    "\n",
    "    Args:\n",
    "        rows : List of stat row dicts from collect_table_stats()\n",
    "        cfg  : Runtime config dict\n",
    "    \"\"\"\n",
    "    if not rows:\n",
    "        return\n",
    "\n",
    "    output_table = f\"{cfg['default_catalog']}.{cfg['output_schema']}.regression_stats\"\n",
    "\n",
    "    try:\n",
    "        df = spark.createDataFrame(pd.DataFrame(rows))\n",
    "        df.write.format('delta').mode('append').saveAsTable(output_table)\n",
    "        logger.info(f'Wrote {len(rows)} stat rows to {output_table}')\n",
    "    except Exception as e:\n",
    "        logger.error(f'Failed to write stats: {e}')\n",
    "\n",
    "\n",
    "def build_summary_row(cfg: dict, tc: dict, detail_rows: list, total_duration: float) -> dict:\n",
    "    \"\"\"\n",
    "    Build a SUMMARY row from a list of DETAIL rows for a table.\n",
    "\n",
    "    Overall status:\n",
    "      - PASSED  : all checks passed\n",
    "      - FAILED  : at least one check failed\n",
    "      - WARNED  : no failures but at least one warning\n",
    "    \"\"\"\n",
    "    statuses   = [r['check_status'] for r in detail_rows]\n",
    "    n_total    = len(statuses)\n",
    "    n_passed   = statuses.count('PASSED')\n",
    "    n_failed   = statuses.count('FAILED')\n",
    "    n_warned   = statuses.count('WARNED') + statuses.count('SKIPPED')\n",
    "\n",
    "    if n_failed > 0:\n",
    "        overall = 'FAILED'\n",
    "    elif n_warned > 0:\n",
    "        overall = 'WARNED'\n",
    "    else:\n",
    "        overall = 'PASSED'\n",
    "\n",
    "    failed_checks = list({r['check_type'] for r in detail_rows if r['check_status'] == 'FAILED'})\n",
    "    failure_summary = f'Failed checks: {failed_checks}' if failed_checks else None\n",
    "\n",
    "    return make_result_row(\n",
    "        cfg, tc,\n",
    "        row_type       = 'SUMMARY',\n",
    "        check_type     = 'SUMMARY',\n",
    "        check_status   = overall,\n",
    "        failure_reason = failure_summary,\n",
    "        checks_total   = n_total,\n",
    "        checks_passed  = n_passed,\n",
    "        checks_failed  = n_failed,\n",
    "        checks_warned  = n_warned,\n",
    "        duration_seconds = total_duration\n",
    "    )\n",
    "\n",
    "print('Delta writers ready.')"
   ]
  },
