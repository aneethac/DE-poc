    "# ============================================================\n",
    "# CELL 3 — RUNTIME CONFIG\n",
    "# Reads all widget values into a single config dict.\n",
    "# When calling from R Jobs API, pass these as notebook_params.\n",
    "# ============================================================\n",
    "def get_runtime_config() -> dict:\n",
    "    \"\"\"Read all widget values into a config dict.\"\"\"\n",
    "    default_catalog = dbutils.widgets.get('catalog')\n",
    "    src_catalog     = dbutils.widgets.get('source_catalog').strip() or default_catalog\n",
    "    tgt_catalog     = dbutils.widgets.get('target_catalog').strip() or default_catalog\n",
    "\n",
    "    return {\n",
    "        'run_id'              : str(uuid.uuid4()),\n",
    "        'run_timestamp'       : datetime.now(timezone.utc),\n",
    "        'default_catalog'     : default_catalog,\n",
    "        'source_catalog'      : src_catalog,\n",
    "        'target_catalog'      : tgt_catalog,\n",
    "        'source_schema'       : dbutils.widgets.get('source_schema'),\n",
    "        'target_schema'       : dbutils.widgets.get('target_schema'),\n",
    "        'output_schema'       : dbutils.widgets.get('output_schema'),\n",
    "        'csv_path'            : dbutils.widgets.get('csv_path'),\n",
    "        'html_output_path'    : dbutils.widgets.get('html_output_path').rstrip('/') + '/',\n",
    "        'max_workers'         : int(dbutils.widgets.get('max_workers') or 4),\n",
    "        'webhook_url'         : dbutils.widgets.get('webhook_url').strip() or None,\n",
    "        'row_count_threshold' : int(dbutils.widgets.get('row_count_threshold') or 50_000_000),\n",
    "    }\n",
    "\n",
    "CFG = get_runtime_config()\n",
    "print(f\"Run ID : {CFG['run_id']}\")\n",
    "print(f\"Source : {CFG['source_catalog']}.{CFG['source_schema']}\")\n",
    "print(f\"Target : {CFG['target_catalog']}.{CFG['target_schema']}\")\n",
    "print(f\"Output : {CFG['default_catalog']}.{CFG['output_schema']}\")\n",
    "print(f\"Workers: {CFG['max_workers']}\")"
   ]
