    "print(f\"  Passed    : {RUN_SUMMARY['n_passed']}\")\n",
    "print(f\"  Failed    : {RUN_SUMMARY['n_failed']}\")\n",
    "print(f\"  Warned    : {RUN_SUMMARY['n_warned']}\")\n",
    "print(f\"  Duration  : {RUN_SUMMARY['duration_sec']}s\")\n",
    "print(f\"  Reports   : {RUN_SUMMARY['html_reports']}\")\n",
    "if RUN_SUMMARY['failed_tables']:\n",
