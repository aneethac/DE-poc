   "source": ["---\n## Section 6 — Per-Table Runner\nOrchestrates all checks for a single table with full error isolation."]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# ============================================================\n",
    "# CELL 14 — PER-TABLE RUNNER\n",
    "# Runs all checks for one table. Any exception is caught and logged.\n",
    "# Called in parallel by the main runner.\n",
    "# ============================================================\n",
    "\n",
    "def run_table(spark: SparkSession, tc: dict, cfg: dict, runtime_cfg: dict) -> dict:\n",
    "    \"\"\"\n",
    "    Run all configured checks for a single table pair.\n",
    "\n",
    "    Args:\n",
    "        tc          : Table config dict from parse_config()\n",
    "        cfg         : Runtime config dict\n",
    "        runtime_cfg : Same as cfg (alias for clarity in parallel context)\n",
    "\n",
    "    Returns:\n",
    "        Dict with 'result_rows', 'stat_rows', 'status' keys\n",
    "    \"\"\"\n",
    "    table_start  = time.time()\n",
    "    detail_rows  = []\n",
    "    stat_rows    = []\n",
    "    output_stats_table = f\"{cfg['default_catalog']}.{cfg['output_schema']}.regression_stats\"\n",
    "\n",
    "    logger.info(f\"Starting: {tc['source_full']} → {tc['target_full']}\")\n",
    "\n",
    "    try:\n",
    "        # ---- 1. Schema check (always runs, no data load needed) ----\n",
    "        detail_rows += check_schema(spark, cfg, tc)\n",
    "\n",
    "        # ---- 2. Row count check ----\n",
    "        detail_rows += check_row_count(spark, cfg, tc, runtime_cfg)\n",
    "\n",
    "        # ---- 3. Load tables (with partition filter + column filter) ----\n",
    "        src_df = load_table(spark, tc['source_full'], tc)\n",
    "        tgt_df = load_table(spark, tc['target_full'], tc)\n",
    "\n",
    "        # ---- Handle type mismatches: safe cast target columns to source types ----\n",
    "        src_schema_map = {f.name: str(f.dataType) for f in src_df.schema.fields}\n",
    "        tgt_schema_map = {f.name: str(f.dataType) for f in tgt_df.schema.fields}\n",
    "        for col in src_schema_map:\n",
    "            if col in tgt_schema_map and src_schema_map[col] != tgt_schema_map[col]:\n",
    "                try:\n",
    "                    tgt_df = safe_cast_column(tgt_df, col, src_schema_map[col])\n",
    "                    logger.info(f'Safe cast {col}: {tgt_schema_map[col]} → {src_schema_map[col]}')\n",
    "                except Exception as cast_err:\n",
    "                    logger.warning(f'Safe cast failed for {col}: {cast_err}')\n",
    "\n",
    "        # ---- Cache both DataFrames ----\n",
    "        src_df.cache()\n",
    "        tgt_df.cache()\n",
    "\n",
    "        # ---- Detect column types ----\n",
    "        col_types = get_column_types(src_df, tc.get('col_type_overrides', {}))\n",
    "\n",
    "        # ---- 4. Aggregate checks ----\n",
    "        detail_rows += check_aggregates(spark, cfg, tc, src_df, tgt_df, col_types)\n",
    "\n",
    "        # ---- 5. Column profile checks ----\n",
    "        detail_rows += check_column_profiles(spark, cfg, tc, src_df, tgt_df, col_types)\n",
    "\n",
    "        # ---- 6. Partition checks ----\n",
    "        detail_rows += check_partitions(spark, cfg, tc)\n",
    "\n",
    "        # ---- 7. Duplicate check (if flagged) ----\n",
    "        if tc.get('check_duplicates'):\n",
    "            detail_rows += check_duplicates(spark, cfg, tc, src_df, tgt_df, runtime_cfg)\n",
    "\n",
    "        # ---- 8. RI check (if flagged) ----\n",
    "        if tc.get('check_ri'):\n",
    "            detail_rows += check_referential_integrity(spark, cfg, tc, runtime_cfg)\n",
    "\n",
    "        # ---- 9. Custom SQL (if provided) ----\n",
    "        if tc.get('custom_sql'):\n",
    "            detail_rows += check_custom_sql(spark, cfg, tc)\n",
    "\n",
    "        # ---- 10. Stats collection (if flagged) ----\n",
    "        if tc.get('collect_stats'):\n",
    "            src_stats = collect_table_stats(spark, cfg, tc, src_df, 'SOURCE', tc['source_full'], col_types)\n",
    "            tgt_stats = collect_table_stats(spark, cfg, tc, tgt_df, 'TARGET', tc['target_full'], col_types)\n",
    "            src_stats = compute_drift_flags(spark, cfg, tc, src_stats, output_stats_table)\n",
    "            stat_rows = src_stats + tgt_stats\n",
    "\n",
    "        # ---- Unpersist cache ----\n",
    "        src_df.unpersist()\n",
    "        tgt_df.unpersist()\n",
    "\n",
    "    except Exception as e:\n",
    "        # Catastrophic failure for this table — log it and continue\n",
    "        error_msg = f'Unexpected error: {str(e)}\\n{traceback.format_exc()}'\n",
    "        logger.error(f\"{tc['source_full']}: {error_msg}\")\n",
    "        detail_rows.append(make_result_row(\n",
    "            cfg, tc, 'DETAIL', 'FRAMEWORK_ERROR',\n",
    "            'FAILED', error_msg,\n",
    "            duration_seconds=round(time.time() - table_start, 2)\n",
    "        ))\n",
    "\n",
    "    # ---- Build summary row ----\n",
    "    total_duration = round(time.time() - table_start, 2)\n",
    "    summary_row    = build_summary_row(cfg, tc, detail_rows, total_duration)\n",
    "    all_result_rows = detail_rows + [summary_row]\n",
    "\n",
    "    logger.info(\n",
    "        f\"Done: {tc['source_full']} | \"\n",
    "        f\"Status={summary_row['check_status']} | \"\n",
    "        f\"Checks: {summary_row['checks_total']} total, \"\n",
    "        f\"{summary_row['checks_passed']} passed, \"\n",
    "        f\"{summary_row['checks_failed']} failed | \"\n",
    "        f\"{total_duration}s\"\n",
    "    )\n",
    "\n",
    "    return {\n",
    "        'result_rows' : all_result_rows,\n",
    "        'stat_rows'   : stat_rows,\n",
    "        'status'      : summary_row['check_status'],\n",
    "        'table'       : tc['source_full'],\n",
    "    }\n",
    "\n",
    "print('Per-table runner ready.')"
   ]
  },
