    "# ============================================================\n",
    "# CELL 6 — SCHEMA DIFF CHECK\n",
    "# Compares column names, types, and counts between source and target.\n",
    "# ============================================================\n",
    "\n",
    "def check_schema(spark: SparkSession, cfg: dict, tc: dict) -> list:\n",
    "    \"\"\"\n",
    "    Compare schema between source and target tables.\n",
    "\n",
    "    Checks:\n",
    "      - Column count match\n",
    "      - Columns in source but missing in target\n",
    "      - Columns in target but missing in source\n",
    "      - Data type differences for matched columns\n",
    "\n",
    "    Returns: List of result row dicts\n",
    "    \"\"\"\n",
    "    results = []\n",
    "    t_start = time.time()\n",
    "\n",
    "    try:\n",
    "        src_schema = {f.name: str(f.dataType) for f in spark.table(tc['source_full']).schema.fields}\n",
    "        tgt_schema = {f.name: str(f.dataType) for f in spark.table(tc['target_full']).schema.fields}\n",
    "\n",
    "        src_cols = set(src_schema.keys())\n",
    "        tgt_cols = set(tgt_schema.keys())\n",
    "\n",
    "        duration = round(time.time() - t_start, 2)\n",
    "\n",
    "        # 1. Column count\n",
    "        if len(src_cols) == len(tgt_cols):\n",
    "            results.append(make_result_row(cfg, tc, 'DETAIL', 'schema',\n",
    "                'PASSED', 'Column counts match',\n",
    "                expected_value=len(src_cols), actual_value=len(tgt_cols),\n",
    "                duration_seconds=duration))\n",
    "        else:\n",
    "            results.append(make_result_row(cfg, tc, 'DETAIL', 'schema',\n",
    "                'FAILED', f'Column count mismatch: source={len(src_cols)}, target={len(tgt_cols)}',\n",
    "                expected_value=len(src_cols), actual_value=len(tgt_cols),\n",
    "                duration_seconds=duration))\n",
    "\n",
    "        # 2. Columns only in source\n",
    "        only_in_src = src_cols - tgt_cols\n",
    "        for col in sorted(only_in_src):\n",
    "            results.append(make_result_row(cfg, tc, 'DETAIL', 'schema',\n",
    "                'FAILED', f'Column exists in source but not in target',\n",
    "                column_name=col, expected_value=src_schema[col], actual_value='MISSING',\n",
    "                duration_seconds=duration))\n",
    "\n",
    "        # 3. Columns only in target\n",
    "        only_in_tgt = tgt_cols - src_cols\n",
    "        for col in sorted(only_in_tgt):\n",
    "            results.append(make_result_row(cfg, tc, 'DETAIL', 'schema',\n",
    "                'FAILED', f'Column exists in target but not in source',\n",
    "                column_name=col, expected_value='MISSING', actual_value=tgt_schema[col],\n",
    "                duration_seconds=duration))\n",
    "\n",
    "        # 4. Data type differences\n",
    "        common_cols = src_cols & tgt_cols\n",
    "        for col in sorted(common_cols):\n",
    "            if src_schema[col] != tgt_schema[col]:\n",
    "                results.append(make_result_row(cfg, tc, 'DETAIL', 'schema',\n",
    "                    'WARNED', f'Data type mismatch — will attempt safe cast during comparison',\n",
    "                    column_name=col,\n",
    "                    expected_value=src_schema[col], actual_value=tgt_schema[col],\n",
    "                    duration_seconds=duration))\n",
    "\n",
    "    except Exception as e:\n",
    "        results.append(make_result_row(cfg, tc, 'DETAIL', 'schema',\n",
    "            'FAILED', f'Schema check error: {str(e)}',\n",
    "            duration_seconds=round(time.time() - t_start, 2)))\n",
    "\n",
    "    return results\n",
    "\n",
    "print('Schema check ready.')"
   ]
