    "# ============================================================\n",
    "# CELL 7 — ROW COUNT CHECK\n",
    "# ============================================================\n",
    "\n",
    "def check_row_count(spark: SparkSession, cfg: dict, tc: dict, runtime_cfg: dict) -> list:\n",
    "    \"\"\"\n",
    "    Compare row counts between source and target.\n",
    "\n",
    "    Guards:\n",
    "      - If table is partitioned but no partition filter → WARN + SKIP (unless force_full_scan)\n",
    "      - If row count > threshold and no partition filter → WARN + SKIP (unless force_full_scan)\n",
    "\n",
    "    Returns: List of result row dicts\n",
    "    \"\"\"\n",
    "    results = []\n",
    "    t_start = time.time()\n",
    "\n",
    "    try:\n",
    "        where_clause  = build_partition_filter(tc)\n",
    "        is_partitioned = is_table_partitioned(spark, tc['source_full'])\n",
    "        force          = tc.get('force_full_scan', False)\n",
    "\n",
    "        # Guard: partitioned table with no filter\n",
    "        if is_partitioned and not where_clause and not force:\n",
    "            msg = (f\"Table {tc['source_full']} is partitioned but no partition filter provided. \"\n",
    "                   f\"Set force_full_scan=true in CSV to override.\")\n",
    "            logger.warning(msg)\n",
    "            results.append(make_result_row(cfg, tc, 'DETAIL', 'row_count',\n",
    "                'WARNED', msg, duration_seconds=round(time.time() - t_start, 2)))\n",
    "            return results\n",
    "\n",
    "        src_count = get_table_row_count(spark, tc['source_full'], where_clause)\n",
    "\n",
    "        # Guard: large table with no filter\n",
    "        if src_count > runtime_cfg['row_count_threshold'] and not where_clause and not force:\n",
    "            msg = (f\"Table has {src_count:,} rows (>{runtime_cfg['row_count_threshold']:,}) \"\n",
    "                   f\"with no partition filter. Set force_full_scan=true to override.\")\n",
    "            logger.warning(msg)\n",
    "            results.append(make_result_row(cfg, tc, 'DETAIL', 'row_count',\n",
    "                'WARNED', msg,\n",
    "                expected_value=src_count, duration_seconds=round(time.time() - t_start, 2)))\n",
    "            return results\n",
    "\n",
    "        tgt_count = get_table_row_count(spark, tc['target_full'], where_clause)\n",
    "        duration  = round(time.time() - t_start, 2)\n",
    "\n",
    "        if src_count == tgt_count:\n",
    "            results.append(make_result_row(cfg, tc, 'DETAIL', 'row_count',\n",
    "                'PASSED', f'Row counts match: {src_count:,}',\n",
    "                expected_value=src_count, actual_value=tgt_count,\n",
    "                duration_seconds=duration))\n",
    "        else:\n",
    "            diff = abs(src_count - tgt_count)\n",
    "            pct  = round(diff / max(src_count, 1) * 100, 2)\n",
    "            results.append(make_result_row(cfg, tc, 'DETAIL', 'row_count',\n",
    "                'FAILED', f'Row count mismatch: diff={diff:,} ({pct}%)',\n",
    "                expected_value=src_count, actual_value=tgt_count,\n",
    "                duration_seconds=duration))\n",
    "\n",
    "    except Exception as e:\n",
    "        results.append(make_result_row(cfg, tc, 'DETAIL', 'row_count',\n",
    "            'FAILED', f'Row count check error: {str(e)}',\n",
    "            duration_seconds=round(time.time() - t_start, 2)))\n",
    "\n",
    "    return results\n",
    "\n",
    "print('Row count check ready.')"
   ]
