    "# ============================================================\n",
    "# CELL 9 — COLUMN PROFILE CHECK\n",
    "# Single-pass profiling for categorical, date, and boolean columns.\n",
    "# ============================================================\n",
    "\n",
    "def check_column_profiles(spark: SparkSession, cfg: dict, tc: dict,\n",
    "                           src_df: DataFrame, tgt_df: DataFrame,\n",
    "                           col_types: dict) -> list:\n",
    "    \"\"\"\n",
    "    Compare column profiles for categorical, date, and boolean columns.\n",
    "\n",
    "    Categorical: null%, empty%, distinct count, min/max/avg length, top N\n",
    "    Date       : null%, min, max, range\n",
    "    Boolean    : null%, true%, false%\n",
    "    Complex    : flag presence only\n",
    "\n",
    "    Returns: List of result row dicts\n",
    "    \"\"\"\n",
    "    results = []\n",
    "    t_start = time.time()\n",
    "\n",
    "    try:\n",
    "        top_n       = tc.get('top_n_frequent', 5)\n",
    "        exact_dist  = tc.get('exact_distinct', False)\n",
    "        total_rows_src = src_df.count()\n",
    "        total_rows_tgt = tgt_df.count()\n",
    "\n",
    "        def profile_df(df: DataFrame, total_rows: int) -> dict:\n",
    "            \"\"\"Single-pass profile for all non-numerical columns.\"\"\"\n",
    "            profile = {}\n",
    "\n",
    "            cat_cols  = [c for c, t in col_types.items() if t == 'categorical' and c in df.columns]\n",
    "            date_cols = [c for c, t in col_types.items() if t == 'date'        and c in df.columns]\n",
    "            bool_cols = [c for c, t in col_types.items() if t == 'boolean'     and c in df.columns]\n",
    "            cx_cols   = [c for c, t in col_types.items() if t == 'complex'     and c in df.columns]\n",
    "\n",
    "            # --- Categorical: single-pass aggregation ---\n",
    "            if cat_cols:\n",
    "                cat_aggs = []\n",
    "                for c in cat_cols:\n",
    "                    cat_aggs += [\n",
    "                        F.count(F.when(F.col(c).isNull(), 1)).alias(f'{c}__nulls'),\n",
    "                        F.count(F.when(F.col(c) == '', 1)).alias(f'{c}__empty'),\n",
    "                        (F.approx_count_distinct(c) if not exact_dist else F.countDistinct(c)).alias(f'{c}__distinct'),\n",
    "                        F.min(F.length(F.col(c))).alias(f'{c}__min_len'),\n",
    "                        F.max(F.length(F.col(c))).alias(f'{c}__max_len'),\n",
    "                        F.avg(F.length(F.col(c))).alias(f'{c}__avg_len'),\n",
    "                    ]\n",
    "                cat_row = df.agg(*cat_aggs).collect()[0].asDict()\n",
    "\n",
    "                for c in cat_cols:\n",
    "                    nulls = cat_row.get(f'{c}__nulls', 0) or 0\n",
    "                    profile[c] = {\n",
    "                        'type'       : 'categorical',\n",
    "                        'null_pct'   : round(nulls / max(total_rows, 1) * 100, 4),\n",
    "                        'empty_pct'  : round((cat_row.get(f'{c}__empty', 0) or 0) / max(total_rows, 1) * 100, 4),\n",
    "                        'distinct'   : cat_row.get(f'{c}__distinct', 0),\n",
    "                        'min_len'    : cat_row.get(f'{c}__min_len'),\n",
    "                        'max_len'    : cat_row.get(f'{c}__max_len'),\n",
    "                        'avg_len'    : round(float(cat_row.get(f'{c}__avg_len') or 0), 4),\n",
    "                        'top_n'      : df.groupBy(c).count().orderBy(F.desc('count')).limit(top_n).collect(),\n",
    "                    }\n",
    "\n",
    "            # --- Date/Timestamp: single-pass ---\n",
    "            if date_cols:\n",
    "                date_aggs = []\n",
    "                for c in date_cols:\n",
    "                    date_aggs += [\n",
    "                        F.count(F.when(F.col(c).isNull(), 1)).alias(f'{c}__nulls'),\n",
    "                        F.min(c).cast('string').alias(f'{c}__min'),\n",
    "                        F.max(c).cast('string').alias(f'{c}__max'),\n",
    "                        F.datediff(F.max(c).cast('date'), F.min(c).cast('date')).alias(f'{c}__range'),\n",
    "                    ]\n",
    "                date_row = df.agg(*date_aggs).collect()[0].asDict()\n",
    "                for c in date_cols:\n",
    "                    nulls = date_row.get(f'{c}__nulls', 0) or 0\n",
    "                    profile[c] = {\n",
    "                        'type'      : 'date',\n",
    "                        'null_pct'  : round(nulls / max(total_rows, 1) * 100, 4),\n",
    "                        'min'       : date_row.get(f'{c}__min'),\n",
    "                        'max'       : date_row.get(f'{c}__max'),\n",
    "                        'range_days': date_row.get(f'{c}__range'),\n",
    "                    }\n",
    "\n",
    "            # --- Boolean: single-pass ---\n",
    "            if bool_cols:\n",
    "                bool_aggs = []\n",
    "                for c in bool_cols:\n",
    "                    bool_aggs += [\n",
    "                        F.count(F.when(F.col(c).isNull(), 1)).alias(f'{c}__nulls'),\n",
    "                        F.count(F.when(F.col(c) == True, 1)).alias(f'{c}__true'),\n",
    "                        F.count(F.when(F.col(c) == False, 1)).alias(f'{c}__false'),\n",
    "                    ]\n",
    "                bool_row = df.agg(*bool_aggs).collect()[0].asDict()\n",
    "                for c in bool_cols:\n",
    "                    nulls = bool_row.get(f'{c}__nulls', 0) or 0\n",
    "                    profile[c] = {\n",
    "                        'type'      : 'boolean',\n",
    "                        'null_pct'  : round(nulls / max(total_rows, 1) * 100, 4),\n",
    "                        'true_pct'  : round((bool_row.get(f'{c}__true', 0) or 0) / max(total_rows, 1) * 100, 4),\n",
    "                        'false_pct' : round((bool_row.get(f'{c}__false', 0) or 0) / max(total_rows, 1) * 100, 4),\n",
    "                    }\n",
    "\n",
    "            # --- Complex: just flag presence ---\n",
    "            for c in cx_cols:\n",
    "                profile[c] = {'type': 'complex'}\n",
    "\n",
    "            return profile\n",
    "\n",
    "        src_profile = profile_df(src_df, total_rows_src)\n",
    "        tgt_profile = profile_df(tgt_df, total_rows_tgt)\n",
    "        duration    = round(time.time() - t_start, 2)\n",
    "\n",
    "        all_cols = set(src_profile.keys()) | set(tgt_profile.keys())\n",
    "\n",
    "        for col in sorted(all_cols):\n",
    "            sp = src_profile.get(col, {})\n",
    "            tp = tgt_profile.get(col, {})\n",
    "            col_type = sp.get('type', tp.get('type', 'unknown'))\n",
    "\n",
    "            if col_type == 'complex':\n",
    "                results.append(make_result_row(cfg, tc, 'DETAIL', 'column_profile',\n",
    "                    'PASSED', 'Complex column — presence confirmed, profiling skipped',\n",
    "                    column_name=col, duration_seconds=duration))\n",
    "                continue\n",
    "\n",
    "            # Compare null%\n",
    "            s_null = sp.get('null_pct', 0)\n",
    "            t_null = tp.get('null_pct', 0)\n",
    "            null_diff = abs(s_null - t_null)\n",
    "            results.append(make_result_row(cfg, tc, 'DETAIL', 'column_profile',\n",
    "                'PASSED' if null_diff == 0 else 'FAILED',\n",
    "                f'null_pct: source={s_null}%, target={t_null}%, diff={null_diff}%',\n",
    "                column_name=f'{col}.null_pct',\n",
    "                expected_value=s_null, actual_value=t_null,\n",
    "                duration_seconds=duration))\n",
    "\n",
    "            # Compare distinct count\n",
    "            s_dist = sp.get('distinct')\n",
    "            t_dist = tp.get('distinct')\n",
    "            if s_dist is not None and t_dist is not None:\n",
    "                results.append(make_result_row(cfg, tc, 'DETAIL', 'column_profile',\n",
    "                    'PASSED' if s_dist == t_dist else 'FAILED',\n",
    "                    f'distinct_count: source={s_dist}, target={t_dist}',\n",
    "                    column_name=f'{col}.distinct_count',\n",
    "                    expected_value=s_dist, actual_value=t_dist,\n",
    "                    duration_seconds=duration))\n",
    "\n",
    "            # Categorical-specific\n",
    "            if col_type == 'categorical':\n",
    "                s_empty = sp.get('empty_pct', 0)\n",
    "                t_empty = tp.get('empty_pct', 0)\n",
    "                results.append(make_result_row(cfg, tc, 'DETAIL', 'column_profile',\n",
    "                    'PASSED' if s_empty == t_empty else 'FAILED',\n",
    "                    f'empty_pct: source={s_empty}%, target={t_empty}%',\n",
    "                    column_name=f'{col}.empty_pct',\n",
    "                    expected_value=s_empty, actual_value=t_empty,\n",
    "                    duration_seconds=duration))\n",
    "\n",
    "                # Top N comparison\n",
    "                src_top = [r[col] for r in sp.get('top_n', [])] if sp.get('top_n') else []\n",
    "                tgt_top = [r[col] for r in tp.get('top_n', [])] if tp.get('top_n') else []\n",
    "                results.append(make_result_row(cfg, tc, 'DETAIL', 'column_profile',\n",
    "                    'PASSED' if src_top == tgt_top else 'WARNED',\n",
    "                    f'top_{top_n}_values differ' if src_top != tgt_top else f'top_{top_n}_values match',\n",
    "                    column_name=f'{col}.top_{top_n}',\n",
    "                    expected_value=str(src_top), actual_value=str(tgt_top),\n",
    "                    duration_seconds=duration))\n",
    "\n",
    "            # Date-specific\n",
    "            if col_type == 'date':\n",
    "                for metric in ['min', 'max', 'range_days']:\n",
    "                    s_v = sp.get(metric)\n",
    "                    t_v = tp.get(metric)\n",
    "                    results.append(make_result_row(cfg, tc, 'DETAIL', 'column_profile',\n",
    "                        'PASSED' if s_v == t_v else 'FAILED',\n",
    "                        f'{metric}: source={s_v}, target={t_v}',\n",
    "                        column_name=f'{col}.{metric}',\n",
    "                        expected_value=s_v, actual_value=t_v,\n",
    "                        duration_seconds=duration))\n",
    "\n",
    "            # Boolean-specific\n",
    "            if col_type == 'boolean':\n",
    "                for metric in ['true_pct', 'false_pct']:\n",
    "                    s_v = sp.get(metric, 0)\n",
    "                    t_v = tp.get(metric, 0)\n",
    "                    results.append(make_result_row(cfg, tc, 'DETAIL', 'column_profile',\n",
    "                        'PASSED' if s_v == t_v else 'FAILED',\n",
    "                        f'{metric}: source={s_v}%, target={t_v}%',\n",
    "                        column_name=f'{col}.{metric}',\n",
    "                        expected_value=s_v, actual_value=t_v,\n",
    "                        duration_seconds=duration))\n",
    "\n",
    "    except Exception as e:\n",
    "        results.append(make_result_row(cfg, tc, 'DETAIL', 'column_profile',\n",
    "            'FAILED', f'Column profile check error: {str(e)}',\n",
    "            duration_seconds=round(time.time() - t_start, 2)))\n",
    "\n",
    "    return results\n",
    "\n",
    "print('Column profile check ready.')"
   ]
