    "# ============================================================\n",
    "# CELL 10 — PARTITION CHECKS\n",
    "# ============================================================\n",
    "\n",
    "def check_partitions(spark: SparkSession, cfg: dict, tc: dict) -> list:\n",
    "    \"\"\"\n",
    "    Partition-level checks between source and target.\n",
    "\n",
    "    Checks:\n",
    "      - Partition key match (same partition columns used)\n",
    "      - Partition count match\n",
    "      - Per-partition row count match\n",
    "      - Partition skew detection (size distribution)\n",
    "\n",
    "    Returns: List of result row dicts\n",
    "    \"\"\"\n",
    "    results = []\n",
    "    t_start = time.time()\n",
    "\n",
    "    try:\n",
    "        def get_partition_info(full_path: str) -> tuple:\n",
    "            detail = spark.sql(f'DESCRIBE DETAIL {full_path}').collect()[0]\n",
    "            return detail['partitionColumns'] or []\n",
    "\n",
    "        src_parts = get_partition_info(tc['source_full'])\n",
    "        tgt_parts = get_partition_info(tc['target_full'])\n",
    "        duration  = round(time.time() - t_start, 2)\n",
    "\n",
    "        # 1. Partition key match\n",
    "        if sorted(src_parts) == sorted(tgt_parts):\n",
    "            results.append(make_result_row(cfg, tc, 'DETAIL', 'partition',\n",
    "                'PASSED', f'Partition keys match: {src_parts}',\n",
    "                expected_value=str(src_parts), actual_value=str(tgt_parts),\n",
    "                duration_seconds=duration))\n",
    "        else:\n",
    "            results.append(make_result_row(cfg, tc, 'DETAIL', 'partition',\n",
    "                'FAILED', f'Partition key mismatch',\n",
    "                expected_value=str(src_parts), actual_value=str(tgt_parts),\n",
    "                duration_seconds=duration))\n",
    "            return results  # Can't do per-partition checks if keys differ\n",
    "\n",
    "        if not src_parts:\n",
    "            results.append(make_result_row(cfg, tc, 'DETAIL', 'partition',\n",
    "                'PASSED', 'Table has no partition columns — partition checks skipped',\n",
    "                duration_seconds=duration))\n",
    "            return results\n",
    "\n",
    "        # 2. Partition count\n",
    "        src_partition_count = spark.sql(f'SHOW PARTITIONS {tc[\"source_full\"]}').count()\n",
    "        tgt_partition_count = spark.sql(f'SHOW PARTITIONS {tc[\"target_full\"]}').count()\n",
    "\n",
    "        results.append(make_result_row(cfg, tc, 'DETAIL', 'partition',\n",
    "            'PASSED' if src_partition_count == tgt_partition_count else 'FAILED',\n",
    "            f'Partition count: source={src_partition_count}, target={tgt_partition_count}',\n",
    "            expected_value=src_partition_count, actual_value=tgt_partition_count,\n",
    "            duration_seconds=duration))\n",
    "\n",
    "        # 3. Per-partition row counts (using partition key from config if provided)\n",
    "        partition_key = tc.get('partition_key')\n",
    "        if partition_key and partition_key in src_parts:\n",
    "            src_counts = (\n",
    "                spark.table(tc['source_full'])\n",
    "                .groupBy(partition_key)\n",
    "                .count()\n",
    "                .withColumnRenamed('count', 'src_count')\n",
    "            )\n",
    "            tgt_counts = (\n",
    "                spark.table(tc['target_full'])\n",
    "                .groupBy(partition_key)\n",
    "                .count()\n",
    "                .withColumnRenamed('count', 'tgt_count')\n",
    "            )\n",
    "            joined = src_counts.join(tgt_counts, on=partition_key, how='full_outer').cache()\n",
    "\n",
    "            mismatches = joined.filter(\n",
    "                F.col('src_count') != F.col('tgt_count') |\n",
    "                F.col('src_count').isNull() |\n",
    "                F.col('tgt_count').isNull()\n",
    "            ).collect()\n",
    "\n",
    "            total_partitions = joined.count()\n",
    "            joined.unpersist()\n",
    "\n",
    "            if not mismatches:\n",
    "                results.append(make_result_row(cfg, tc, 'DETAIL', 'partition',\n",
    "                    'PASSED', f'All {total_partitions} partitions have matching row counts',\n",
    "                    duration_seconds=round(time.time() - t_start, 2)))\n",
    "            else:\n",
    "                for row in mismatches[:20]:  # Cap at 20 to avoid too many rows\n",
    "                    pval = str(row[partition_key])\n",
    "                    results.append(make_result_row(cfg, tc, 'DETAIL', 'partition',\n",
    "                        'FAILED', f'Row count mismatch for partition {partition_key}={pval}',\n",
    "                        partition_value=pval,\n",
    "                        expected_value=row['src_count'], actual_value=row['tgt_count'],\n",
    "                        duration_seconds=round(time.time() - t_start, 2)))\n",
    "\n",
    "            # 4. Skew detection: flag if any partition is >3x the median size\n",
    "            src_partition_df = spark.table(tc['source_full']).groupBy(partition_key).count()\n",
    "            median_count     = src_partition_df.approxQuantile('count', [0.5], 0.01)[0]\n",
    "            skewed           = src_partition_df.filter(F.col('count') > median_count * 3).collect()\n",
    "\n",
    "            if skewed:\n",
    "                skew_vals = [str(r[partition_key]) for r in skewed]\n",
    "                results.append(make_result_row(cfg, tc, 'DETAIL', 'partition',\n",
    "                    'WARNED', f'Partition skew detected (>3x median) in {len(skewed)} partitions: {skew_vals[:5]}',\n",
    "                    duration_seconds=round(time.time() - t_start, 2)))\n",
    "            else:\n",
    "                results.append(make_result_row(cfg, tc, 'DETAIL', 'partition',\n",
    "                    'PASSED', 'No significant partition skew detected',\n",
    "                    duration_seconds=round(time.time() - t_start, 2)))\n",
    "\n",
    "    except Exception as e:\n",
    "        results.append(make_result_row(cfg, tc, 'DETAIL', 'partition',\n",
    "            'FAILED', f'Partition check error: {str(e)}',\n",
    "            duration_seconds=round(time.time() - t_start, 2)))\n",
    "\n",
    "    return results\n",
    "\n",
    "print('Partition check ready.')"
   ]
  },
