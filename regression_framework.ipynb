    "    for t in RUN_SUMMARY['failed_tables']:\n",
    "        print(f\"    - {t}\")\n",
    "print('='*60)\n",
    "\n",
    "# Send webhook alert (if configured and failures exist)\n",
    "send_webhook_alert(CFG, RUN_SUMMARY)\n",
    "\n",
    "# Raise Databricks job alert (uncomment to enable native job failure notification)\n",
    "# raise_databricks_job_alert(RUN_SUMMARY)"
   ]
