   "cell_type": "markdown",
   "metadata": {},
   "source": ["---\n## Section 1 — Config Parser\nReads and validates the input CSV. Each row = one table pair to compare."]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# ============================================================\n",
    "# CELL 4 — CONFIG PARSER\n",
    "# Reusable: parse_config(csv_path) returns list of table configs.\n",
    "# ============================================================\n",
    "\n",
    "# Default values for all optional CSV columns\n",
    "CSV_DEFAULTS = {\n",
    "    'filter_condition'         : None,\n",
    "    'column_exclusions'        : None,\n",
    "    'column_inclusions'        : None,\n",
    "    'primary_keys'             : None,\n",
    "    'col_type_overrides'       : None,\n",
    "    'aggregate_tolerance_abs'  : 0.0,\n",
    "    'aggregate_tolerance_rel'  : 0.0,\n",
    "    'collect_stats'            : False,\n",
    "    'check_duplicates'         : False,\n",
    "    'check_ri'                 : False,\n",
    "    'custom_sql'               : None,\n",
    "    'partition_key'            : None,\n",
    "    'partition_start'          : None,\n",
    "    'partition_end'            : None,\n",
    "    'partition_values'         : None,\n",
    "    'top_n_frequent'           : 5,\n",
    "    'exact_distinct'           : False,\n",
    "    'enable_mode'              : False,\n",
    "    'force_full_scan'          : False,\n",
    "    'force_duplicate_scan'     : False,\n",
    "    'force_ri_scan'            : False,\n",
    "    'drift_null_pct_threshold'      : None,\n",
    "    'drift_distinct_pct_threshold'  : None,\n",
    "    'drift_rowcount_pct_threshold'  : None,\n",
    "    'drift_numeric_mean_threshold'  : None,\n",
    "}\n",
    "\n",
    "def _parse_bool(val) -> bool:\n",
    "    \"\"\"Convert CSV string to bool.\"\"\"\n",
    "    if isinstance(val, bool): return val\n",
    "    if pd.isna(val): return False\n",
    "    return str(val).strip().lower() in ('true', '1', 'yes')\n",
    "\n",
    "def _parse_list(val, sep=';') -> list:\n",
    "    \"\"\"Convert semicolon-separated string to list.\"\"\"\n",
    "    if pd.isna(val) or not str(val).strip(): return []\n",
    "    return [x.strip() for x in str(val).split(sep) if x.strip()]\n",
    "\n",
    "def _parse_float(val, default=0.0) -> float:\n",
    "    \"\"\"Safely parse float.\"\"\"\n",
    "    try:\n",
    "        if pd.isna(val): return default\n",
    "        return float(val)\n",
    "    except Exception:\n",
    "        return default\n",
    "\n",
    "def _parse_int(val, default=None):\n",
    "    \"\"\"Safely parse int.\"\"\"\n",
    "    try:\n",
    "        if pd.isna(val): return default\n",
    "        return int(val)\n",
    "    except Exception:\n",
    "        return default\n",
    "\n",
    "def parse_config(csv_path: str, cfg: dict) -> list:\n",
    "    \"\"\"\n",
    "    Parse the regression config CSV.\n",
    "\n",
    "    Args:\n",
    "        csv_path : Path to CSV (local, DBFS, or DBFS fuse path)\n",
    "        cfg      : Runtime config dict from get_runtime_config()\n",
    "\n",
    "    Returns:\n",
    "        List of table config dicts, one per row.\n",
    "    \"\"\"\n",
    "    # Support /dbfs/ paths and dbfs:/ paths\n",
    "    read_path = csv_path.replace('dbfs:/', '/dbfs/')\n",
    "    df = pd.read_csv(read_path, dtype=str, keep_default_na=False, na_values=[''])\n",
    "\n",
    "    # Apply defaults for missing columns\n",
    "    for col, default in CSV_DEFAULTS.items():\n",
    "        if col not in df.columns:\n",
    "            df[col] = default\n",
    "\n",
    "    required = ['source_schema', 'source_table', 'target_schema', 'target_table']\n",
    "    for col in required:\n",
    "        if col not in df.columns:\n",
    "            raise ValueError(f'Required column missing from CSV: {col}')\n",
    "\n",
    "    table_configs = []\n",
    "    for _, row in df.iterrows():\n",
    "        tc = {\n",
    "            # Table identification\n",
    "            'source_schema'  : str(row['source_schema']).strip(),\n",
    "            'source_table'   : str(row['source_table']).strip(),\n",
    "            'target_schema'  : str(row['target_schema']).strip(),\n",
    "            'target_table'   : str(row['target_table']).strip(),\n",
    "            'source_catalog' : cfg['source_catalog'],\n",
    "            'target_catalog' : cfg['target_catalog'],\n",
    "\n",
    "            # Derived full paths\n",
    "            'source_full'    : f\"{cfg['source_catalog']}.{row['source_schema'].strip()}.{row['source_table'].strip()}\",\n",
    "            'target_full'    : f\"{cfg['target_catalog']}.{row['target_schema'].strip()}.{row['target_table'].strip()}\",\n",
    "\n",
    "            # Filtering\n",
    "            'filter_condition'   : row.get('filter_condition') or None,\n",
    "            'column_exclusions'  : _parse_list(row.get('column_exclusions')),\n",
    "            'column_inclusions'  : _parse_list(row.get('column_inclusions')),\n",
    "            'primary_keys'       : _parse_list(row.get('primary_keys')),\n",
    "\n",
    "            # Column type overrides: format col:type;col2:type2\n",
    "            'col_type_overrides' : dict(\n",
    "                x.split(':') for x in _parse_list(row.get('col_type_overrides'))\n",
    "                if ':' in str(x)\n",
    "            ),\n",
    "\n",
    "            # Tolerances\n",
    "            'aggregate_tolerance_abs' : _parse_float(row.get('aggregate_tolerance_abs'), 0.0),\n",
    "            'aggregate_tolerance_rel' : _parse_float(row.get('aggregate_tolerance_rel'), 0.0),\n",
    "\n",
    "            # Feature flags\n",
    "            'collect_stats'        : _parse_bool(row.get('collect_stats')),\n",
    "            'check_duplicates'     : _parse_bool(row.get('check_duplicates')),\n",
    "            'check_ri'             : _parse_bool(row.get('check_ri')),\n",
    "            'custom_sql'           : row.get('custom_sql') or None,\n",
    "            'exact_distinct'       : _parse_bool(row.get('exact_distinct')),\n",
    "            'enable_mode'          : _parse_bool(row.get('enable_mode')),\n",
    "            'force_full_scan'      : _parse_bool(row.get('force_full_scan')),\n",
    "            'force_duplicate_scan' : _parse_bool(row.get('force_duplicate_scan')),\n",
    "            'force_ri_scan'        : _parse_bool(row.get('force_ri_scan')),\n",
    "\n",
    "            # Partition config\n",
    "            'partition_key'    : row.get('partition_key') or None,\n",
    "            'partition_start'  : row.get('partition_start') or None,\n",
    "            'partition_end'    : row.get('partition_end') or None,\n",
    "            'partition_values' : _parse_list(row.get('partition_values')),\n",
    "\n",
    "            # Stats config\n",
    "            'top_n_frequent' : _parse_int(row.get('top_n_frequent'), 5),\n",
    "\n",
    "            # Drift thresholds (None = drift check skipped)\n",
    "            'drift_null_pct_threshold'     : _parse_float(row.get('drift_null_pct_threshold')) if row.get('drift_null_pct_threshold') else None,\n",
    "            'drift_distinct_pct_threshold' : _parse_float(row.get('drift_distinct_pct_threshold')) if row.get('drift_distinct_pct_threshold') else None,\n",
    "            'drift_rowcount_pct_threshold' : _parse_float(row.get('drift_rowcount_pct_threshold')) if row.get('drift_rowcount_pct_threshold') else None,\n",
    "            'drift_numeric_mean_threshold' : _parse_float(row.get('drift_numeric_mean_threshold')) if row.get('drift_numeric_mean_threshold') else None,\n",
    "        }\n",
    "        table_configs.append(tc)\n",
    "\n",
    "    logger.info(f'Parsed {len(table_configs)} table configs from {csv_path}')\n",
    "    return table_configs\n",
    "\n",
    "print('Config parser ready.')"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": ["---\n## Section 2 — Utility Functions\nHelpers for loading tables, detecting column types, building partition filters."]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# ============================================================\n",
    "# CELL 5 — UTILITY FUNCTIONS\n",
    "# All reusable independently outside this framework.\n",
    "# ============================================================\n",
    "\n",
    "# Column type classification\n",
    "NUMERICAL_TYPES  = {'int', 'bigint', 'smallint', 'tinyint', 'double', 'float', 'decimal', 'long'}\n",
    "DATE_TYPES       = {'date', 'timestamp', 'timestamp_ntz'}\n",
    "BOOLEAN_TYPES    = {'boolean'}\n",
    "COMPLEX_TYPES    = {'array', 'map', 'struct'}\n",
    "\n",
    "def detect_column_type(spark_type_str: str) -> str:\n",
    "    \"\"\"\n",
    "    Classify a Spark column type string into framework categories.\n",
    "\n",
    "    Returns: 'numerical' | 'categorical' | 'date' | 'boolean' | 'complex'\n",
    "    \"\"\"\n",
    "    t = spark_type_str.lower().split('(')[0].strip()  # handle decimal(18,2) etc.\n",
    "    if t in NUMERICAL_TYPES : return 'numerical'\n",
    "    if t in DATE_TYPES       : return 'date'\n",
    "    if t in BOOLEAN_TYPES    : return 'boolean'\n",
    "    if any(t.startswith(c) for c in COMPLEX_TYPES): return 'complex'\n",
    "    return 'categorical'\n",
    "\n",
    "def get_column_types(df: DataFrame, overrides: dict = None) -> dict:\n",
    "    \"\"\"\n",
    "    Get column type classification for all columns in a DataFrame.\n",
    "\n",
    "    Args:\n",
    "        df        : Spark DataFrame\n",
    "        overrides : Dict of {col_name: type_override} from CSV config\n",
    "\n",
    "    Returns:\n",
    "        Dict of {col_name: detected_type}\n",
    "    \"\"\"\n",
    "    overrides = overrides or {}\n",
    "    result = {}\n",
    "    for field in df.schema.fields:\n",
    "        if field.name in overrides:\n",
    "            result[field.name] = overrides[field.name].lower()\n",
    "        else:\n",
    "            result[field.name] = detect_column_type(str(field.dataType))\n",
    "    return result\n",
    "\n",
    "def build_partition_filter(tc: dict) -> str:\n",
    "    \"\"\"\n",
    "    Build a SQL WHERE clause from partition config.\n",
    "\n",
    "    Supports:\n",
    "      - Range: partition_start + partition_end  → col BETWEEN start AND end\n",
    "      - List:  partition_values                 → col IN ('a', 'b')\n",
    "      - Single value in partition_values with one item\n",
    "\n",
    "    Returns: SQL filter string or None\n",
    "    \"\"\"\n",
    "    key    = tc.get('partition_key')\n",
    "    start  = tc.get('partition_start')\n",
    "    end    = tc.get('partition_end')\n",
    "    values = tc.get('partition_values', [])\n",
    "\n",
    "    if not key:\n",
    "        return tc.get('filter_condition') or None\n",
    "\n",
    "    if start and end:\n",
    "        partition_filter = f\"{key} BETWEEN '{start}' AND '{end}'\"\n",
    "    elif values:\n",
    "        quoted = ', '.join(f\"'{v}'\" for v in values)\n",
    "        partition_filter = f\"{key} IN ({quoted})\"\n",
    "    else:\n",
    "        partition_filter = None\n",
    "\n",
    "    # Combine with additional filter_condition if present\n",
    "    extra = tc.get('filter_condition')\n",
    "    if partition_filter and extra:\n",
    "        return f\"({partition_filter}) AND ({extra})\"\n",
    "    return partition_filter or extra\n",
    "\n",
    "def apply_column_filter(df: DataFrame, tc: dict) -> DataFrame:\n",
    "    \"\"\"\n",
    "    Apply column inclusions/exclusions to a DataFrame.\n",
    "\n",
    "    - If column_inclusions is set → keep only those columns\n",
    "    - Else if column_exclusions is set → drop those columns\n",
    "    - column_exclusions always applied after inclusions\n",
    "    \"\"\"\n",
    "    inclusions = tc.get('column_inclusions', [])\n",
    "    exclusions = tc.get('column_exclusions', [])\n",
    "\n",
    "    if inclusions:\n",
    "        # Only keep columns that actually exist in the df\n",
    "        cols = [c for c in inclusions if c in df.columns]\n",
    "        df = df.select(cols)\n",
    "\n",
    "    if exclusions:\n",
    "        cols = [c for c in df.columns if c not in exclusions]\n",
    "        df = df.select(cols)\n",
    "\n",
    "    return df\n",
    "\n",
    "def load_table(spark: SparkSession, full_table_path: str, tc: dict) -> DataFrame:\n",
    "    \"\"\"\n",
    "    Load a table applying partition filter and column filters.\n",
    "\n",
    "    Args:\n",
    "        spark           : Active SparkSession\n",
    "        full_table_path : e.g. 'uc_dev0004.biw.fact_sales'\n",
    "        tc              : Table config dict\n",
    "\n",
    "    Returns:\n",
    "        Filtered Spark DataFrame\n",
    "    \"\"\"\n",
    "    where_clause = build_partition_filter(tc)\n",
    "\n",
    "    if where_clause:\n",
    "        df = spark.sql(f'SELECT * FROM {full_table_path} WHERE {where_clause}')\n",
    "    else:\n",
    "        df = spark.table(full_table_path)\n",
    "\n",
    "    df = apply_column_filter(df, tc)\n",
    "    return df\n",
    "\n",
    "def safe_cast_column(df: DataFrame, col_name: str, target_type: str) -> DataFrame:\n",
    "    \"\"\"\n",
    "    Attempt safe cast of a column to target_type.\n",
    "    Returns DataFrame with cast applied (nulls on cast failure).\n",
    "    \"\"\"\n",
    "    return df.withColumn(col_name, F.col(col_name).cast(target_type))\n",
    "\n",
    "def get_table_row_count(spark: SparkSession, full_table_path: str, where_clause: str = None) -> int:\n",
    "    \"\"\"Get row count for a table, optionally filtered.\"\"\"\n",
    "    if where_clause:\n",
    "        return spark.sql(f'SELECT COUNT(*) as cnt FROM {full_table_path} WHERE {where_clause}').collect()[0]['cnt']\n",
    "    return spark.sql(f'SELECT COUNT(*) as cnt FROM {full_table_path}').collect()[0]['cnt']\n",
    "\n",
    "def get_table_size_bytes(spark: SparkSession, full_table_path: str) -> int:\n",
    "    \"\"\"Get table size in bytes from Delta metadata.\"\"\"\n",
    "    try:\n",
    "        detail = spark.sql(f'DESCRIBE DETAIL {full_table_path}').collect()[0]\n",
    "        return detail['sizeInBytes']\n",
    "    except Exception:\n",
    "        return 0\n",
    "\n",
    "def is_table_partitioned(spark: SparkSession, full_table_path: str) -> bool:\n",
    "    \"\"\"Check if a Delta table has partition columns.\"\"\"\n",
    "    try:\n",
    "        detail = spark.sql(f'DESCRIBE DETAIL {full_table_path}').collect()[0]\n",
    "        parts = detail['partitionColumns']\n",
    "        return parts is not None and len(parts) > 0\n",
    "    except Exception:\n",
    "        return False\n",
    "\n",
    "def make_result_row(cfg: dict, tc: dict, row_type: str, check_type: str,\n",
    "                    check_status: str, failure_reason: str = None,\n",
    "                    column_name: str = None, partition_value: str = None,\n",
    "                    expected_value=None, actual_value=None,\n",
    "                    checks_total: int = None, checks_passed: int = None,\n",
    "                    checks_failed: int = None, checks_warned: int = None,\n",
    "                    duration_seconds: float = None) -> dict:\n",
    "    \"\"\"Build a regression_results row dict.\"\"\"\n",
    "    return {\n",
    "        'run_id'           : cfg['run_id'],\n",
    "        'run_timestamp'    : cfg['run_timestamp'],\n",
    "        'row_type'         : row_type,\n",
    "        'source_table'     : tc['source_full'],\n",
    "        'target_table'     : tc['target_full'],\n",
    "        'check_type'       : check_type,\n",
    "        'check_status'     : check_status,\n",
    "        'checks_total'     : checks_total,\n",
    "        'checks_passed'    : checks_passed,\n",
    "        'checks_failed'    : checks_failed,\n",
    "        'checks_warned'    : checks_warned,\n",
    "        'column_name'      : column_name,\n",
    "        'partition_value'  : partition_value,\n",
    "        'expected_value'   : str(expected_value) if expected_value is not None else None,\n",
    "        'actual_value'     : str(actual_value)   if actual_value   is not None else None,\n",
    "        'failure_reason'   : failure_reason,\n",
    "        'duration_seconds' : duration_seconds,\n",
    "    }\n",
    "\n",
    "print('Utility functions ready.')"
