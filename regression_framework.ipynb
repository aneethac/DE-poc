    "dbutils.widgets.text('source_catalog',     '',             'Source Catalog (override)')\n",
    "dbutils.widgets.text('target_catalog',     '',             'Target Catalog (override)')\n",
    "dbutils.widgets.text('source_schema',      'biw',          'Source Schema')\n",
    "dbutils.widgets.text('target_schema',      'biw_sf',       'Target Schema')\n",
    "dbutils.widgets.text('output_schema',      'caife_utils',  'Output Schema')\n",
    "dbutils.widgets.text('csv_path',           '',             'Config CSV Path')\n",
    "dbutils.widgets.text('html_output_path',   '/dbfs/tmp/regression_reports/', 'HTML Report Output Path')\n",
    "dbutils.widgets.text('max_workers',        '4',            'Max Parallel Workers')\n",
    "dbutils.widgets.text('webhook_url',        '',             'Webhook URL (optional)')\n",
    "dbutils.widgets.text('row_count_threshold','50000000',     'Row Count Threshold for full scan warning')"
   ]
